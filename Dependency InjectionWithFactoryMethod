A.java

package com.javatpoint;

public class A {

    // creating static object
    private static final A obj = new A();

    // private constructor
    private A() {
        System.out.println("privateConstructor");
    }

    // factory method
    public static A getA() {
        System.out.println("factoryMethod");
        return obj;
    }

    public void msg() {
        System.out.println("hello user");
    }


